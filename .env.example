# ═══════════════════════════════════════════════════════
#  FLAP FUTURES — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/flapfutures

# ── Session ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# ── On-chain Bot Wallet ───────────────────────────────────
# This wallet pays gas for oracle updates, funding rate posts, and liquidations.
# Fund it with a small amount of BNB (~0.1 BNB to start).
BOT_PRIVATE_KEY=0x_your_bot_wallet_private_key_here

# ── External APIs ─────────────────────────────────────────
# Moralis API key — used for token metadata (name, symbol, logo)
# Get yours free at https://moralis.io
MORALIS_API_KEY=your_moralis_api_key_here

# BSCScan API key — used for contract verification (optional)
BSCSCAN_API_KEY=your_bscscan_api_key_here

# ── Deployed Contract Addresses ───────────────────────────
# Run `node scripts/deployFactory.mjs` to deploy and get these addresses.
FFX_ORACLE=0x_FlapOracle_deployed_address
FFX_FUNDING=0x_FlapFunding_deployed_address
FFX_FACTORY=0x_FlapFactory_deployed_address

# ── App Config ────────────────────────────────────────────
NODE_ENV=production
PORT=5000
